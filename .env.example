# ─── MongoDB ───────────────────────────────────────────────────────────
# Local: docker-compose.yml exposes Mongo on :27017 with the creds below.
# Prod:  replace with the Atlas connection string from the MongoDB Atlas UI.
MONGODB_URI="mongodb://admin:devpassword@localhost:27017/myportfolio?authSource=admin"

# ─── Public ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ─── Session ───────────────────────────────────────────────────────────
SESSION_COOKIE_NAME="myportfolio_session"

# ─── Initial super-admin seed (used by scripts/seed-super-admin.ts) ────
INITIAL_ADMIN_EMAIL="admin@rajukumaryadav.com"
INITIAL_ADMIN_PASSWORD="changeme-locally"
INITIAL_ADMIN_NAME="Raju Kumar Yadav"

# ─── Upload limits ─────────────────────────────────────────────────────
# 10 MB — applied to /api/admin/upload route.
MAX_UPLOAD_BYTES="10485760"

# ─── Optional: Turnstile / hCaptcha (public contact form anti-spam) ────
# Leave blank to disable. Server-side verification skipped if no key.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
