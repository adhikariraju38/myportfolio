# ─── PostgreSQL (Neon) ─────────────────────────────────────────────────
# Local + prod both use the Neon connection string (database: raju_portfolio).
# Get it from the Neon dashboard → Connection Details. Keep `?sslmode=require`.
# On Vercel, set POSTGRES_URI in Project Settings → Environment Variables.
POSTGRES_URI="postgresql://USER:PASSWORD@HOST/raju_portfolio?sslmode=require"

# ─── Public ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ─── Session ───────────────────────────────────────────────────────────
SESSION_COOKIE_NAME="myportfolio_session"

# ─── Initial super-admin seed (used by scripts/seed-super-admin.ts) ────
INITIAL_ADMIN_EMAIL="admin@rajukumaryadav.com"
INITIAL_ADMIN_PASSWORD="changeme-locally"
INITIAL_ADMIN_NAME="Raju Kumar Yadav"

# ─── Upload limits ─────────────────────────────────────────────────────
# 10 MB — applied to /api/admin/upload route.
MAX_UPLOAD_BYTES="10485760"

# ─── Optional: Turnstile / hCaptcha (public contact form anti-spam) ────
# Leave blank to disable. Server-side verification skipped if no key.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
